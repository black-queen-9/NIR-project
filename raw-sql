DROP TABLE IF EXISTS materials      CASCADE;
DROP TABLE IF EXISTS section_types  CASCADE;
DROP TABLE IF EXISTS sections       CASCADE;
DROP TABLE IF EXISTS beams          CASCADE;

CREATE TABLE materials (
    material_id        SERIAL PRIMARY KEY,
    material_name      VARCHAR(100) NOT NULL,
    description_mat    TEXT,
    characteristics    TEXT,
    strength_mpa       NUMERIC(10, 2),
    hardness_hb        NUMERIC(10, 2),
    poisson_ratio      NUMERIC(4, 3),
    young_modulus_gpa  NUMERIC(10, 2)
);

CREATE TABLE section_types (
    section_type_id    SERIAL PRIMARY KEY,
    section_type_name  VARCHAR(100) NOT NULL,
    section_type_desc  TEXT
);

CREATE TABLE sections (
    section_id         SERIAL PRIMARY KEY,
    section_type_id    INT NOT NULL REFERENCES section_types(section_type_id)
                       ON UPDATE CASCADE ON DELETE RESTRICT,
    material_id        INT NOT NULL REFERENCES materials(material_id)
                       ON UPDATE CASCADE ON DELETE RESTRICT,
    section_name       VARCHAR(100) NOT NULL,
    notes              TEXT
);

CREATE TABLE beams (
    beam_id         SERIAL PRIMARY KEY,
    beam_name       VARCHAR(100) NOT NULL,
    section_id      INT NOT NULL REFERENCES sections(section_id)
                    ON UPDATE CASCADE ON DELETE RESTRICT,
    material_id     INT NOT NULL REFERENCES materials(material_id)
                    ON UPDATE CASCADE ON DELETE RESTRICT,
    length_m        NUMERIC(10, 2) NOT NULL,
    notes           TEXT
);


