SELECT * FROM materials;
SELECT * FROM section_types;
SELECT * FROM sections;

SELECT
    s.section_id,
    s.section_name,
    st.section_type_name AS section_type,
    m.material_name      AS material
FROM sections s
JOIN section_types st ON s.section_type_id = st.section_type_id
JOIN materials m      ON s.material_id = m.material_id
ORDER BY s.section_id;

SELECT
    s.section_id,
    s.section_name,
    st.section_type_name AS section_type
FROM sections s
JOIN section_types st ON s.section_type_id = st.section_type_id
JOIN materials m ON s.material_id = m.material_id
WHERE m.material_name = 'Сталь конструкционная';

SELECT
    material_name,
    young_modulus_gpa,
    strength_mpa,
    hardness_hb
FROM materials
WHERE young_modulus_gpa > 150
ORDER BY young_modulus_gpa DESC;

SELECT
    material_name,
    poisson_ratio
FROM materials
WHERE poisson_ratio BETWEEN 0.280 AND 0.320
ORDER BY poisson_ratio;

SELECT
    st.section_type_name,
    COUNT(s.section_id) AS sections_count
FROM section_types st
LEFT JOIN sections s ON s.section_type_id = st.section_type_id
GROUP BY st.section_type_name
ORDER BY st.section_type_name;

SELECT
    m.material_name,
    COUNT(s.section_id) AS sections_count
FROM materials m
LEFT JOIN sections s ON s.material_id = m.material_id
GROUP BY m.material_name
ORDER BY sections_count DESC;

